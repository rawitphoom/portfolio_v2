# Heavy source media — keep originals local only.
# The site ships web-optimized *-web.mp4 versions (see /tmp/portfolio_webconvert.sh).
# Commit ONLY *-web.mp4 and images; never raw .mov/.gif or un-optimized .mp4.
assets/**/*.mov
assets/**/*.gif
assets/**/*.mp4
!assets/**/*-web.mp4
